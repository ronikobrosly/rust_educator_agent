{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "formatter": {
    "rust": {
      "command": ["cargo", "fmt"],
      "extensions": ["rs"]
    }
  },
  "permission": {
    "external_directory": {
      "*": "deny",
      "/home/roni/quickpass/**": "allow"
    },
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "rmdir *": "deny",
      "unlink *": "deny",
      "git rm *": "deny"
    }
  }
}
